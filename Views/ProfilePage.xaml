<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ListImnida.ViewModels"
             x:Class="ListImnida.Views.ProfilePage"
             Title="{Binding Title}">

    <VerticalStackLayout Spacing="15" Padding="30" VerticalOptions="Center">
        
        <Label Text="Profile" 
               FontSize="28" FontAttributes="Bold" 
               HorizontalOptions="Center" 
               TextColor="{StaticResource Primary}"/>

        <Frame Padding="20" CornerRadius="12" HasShadow="False" BorderColor="{StaticResource Secondary}">
            <VerticalStackLayout Spacing="8">
                <Label Text="Full Name" FontAttributes="Bold" TextColor="Gray" />
                <Label Text="{Binding FullName}" FontSize="18" />

                <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

                <Label Text="Email" FontAttributes="Bold" TextColor="Gray" />
                <Label Text="{Binding Email}" FontSize="18" />
            </VerticalStackLayout>
        </Frame>

        <Button Text="Sign Out" 
                Command="{Binding SignOutCommand}" 
                BackgroundColor="IndianRed"
                Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>
