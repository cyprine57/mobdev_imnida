<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:ListImnida.ViewModels"
             x:Class="ListImnida.Views.TodoDetailPage"
             Title="{Binding Title}">

    <VerticalStackLayout Spacing="15" Padding="20">
        
        <Label Text="Title" FontAttributes="Bold" />
        <Entry Text="{Binding ItemTitle}" 
               Placeholder="Enter task title" 
               Keyboard="Text"/>

        <Label Text="Details" FontAttributes="Bold" />
        <Editor Text="{Binding ItemDetails}" 
                Placeholder="Enter task details" 
                HeightRequest="100" 
                Keyboard="Text"/>

        <StackLayout Orientation="Horizontal" Spacing="10" HorizontalOptions="FillAndExpand" Margin="0,20,0,0">
            <Button Text="Update" 
                    Command="{Binding SaveCommand}" 
                    HorizontalOptions="FillAndExpand" />
            
            <Button Text="Complete" 
                    Command="{Binding CompleteCommand}" 
                    Style="{StaticResource AccentButton}"
                    HorizontalOptions="FillAndExpand" />

            <Button Text="Delete" 
                    Command="{Binding DeleteCommand}" 
                    BackgroundColor="IndianRed"
                    HorizontalOptions="FillAndExpand" />
        </StackLayout>
        
    </VerticalStackLayout>
</ContentPage>
