<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:ListImnida"
       xmlns:views="clr-namespace:ListImnida.Views"
       x:Class="ListImnida.AppShell"
       FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="To Do">
            <ShellContent ContentTemplate="{DataTemplate views:TodoListPage}" />
        </Tab>
        <Tab Title="Completed">
            <ShellContent ContentTemplate="{DataTemplate views:CompletedListPage}" />
        </Tab>
        <Tab Title="Profile">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
    </TabBar>

</Shell>
